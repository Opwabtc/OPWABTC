{
    "targets": {
        "token": {
            "outFile": "build/OPWACoin.wasm",
            "use": ["abort=op20/index/abort"]
        },
        "nft": {
            "outFile": "build/PropertyNFT.wasm",
            "use": ["abort=op721/index/abort"]
        },
        "yieldVault": {
            "outFile": "build/YieldVault.wasm",
            "use": ["abort=vault/index_yield/abort"]
        },
        "usdop": {
            "outFile": "build/USDOP.wasm",
            "use": ["abort=vault/index_usdop/abort"]
        },
        "propertyVault": {
            "outFile": "build/PropertyVault.wasm",
            "use": ["abort=vault/index_property/abort"]
        }
    },
    "options": {
        "sourceMap": false,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "converge": true,
        "noAssert": false,
        "enable": [
            "sign-extension", "mutable-globals", "nontrapping-f2i",
            "bulk-memory", "simd", "reference-types", "multi-value"
        ],
        "runtime": "stub",
        "memoryBase": 0,
        "initialMemory": 1,
        "exportStart": "start",
        "transform": "@btc-vision/opnet-transform"
    }
}
